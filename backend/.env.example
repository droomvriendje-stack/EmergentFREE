# Droomvriendjes Backend - Environment Variables
# Copy this file to .env and fill in your values

# ===== SUPABASE (Required) =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ===== MOLLIE PAYMENTS (Required) =====
MOLLIE_API_KEY=live_your-api-key
MOLLIE_PROFILE_ID=pfl_your-profile-id

# ===== URLS (Required) =====
FRONTEND_URL=https://droomvriendjes.nl
API_URL=https://api.droomvriendjes.nl
CORS_ORIGINS=https://droomvriendjes.nl,https://www.droomvriendjes.nl

# ===== EMAIL - Postmark (Recommended) =====
POSTMARK_API_TOKEN=your-postmark-token
SMTP_FROM=info@droomvriendjes.nl

# ===== EMAIL - SMTP Fallback (Optional) =====
SMTP_HOST=smtp.transip.email
SMTP_PORT=465
SMTP_USER=info@droomvriendjes.nl
SMTP_PASSWORD=your-smtp-password

# ===== SENDCLOUD SHIPPING (Optional) =====
SENDCLOUD_PUBLIC_KEY=your-public-key
SENDCLOUD_SECRET_KEY=your-secret-key

# ===== GOOGLE MERCHANT CENTER (Optional) =====
GOOGLE_MERCHANT_CENTER_ID=your-merchant-id
SHOP_URL=https://droomvriendjes.nl

# ===== ADMIN DASHBOARD =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
